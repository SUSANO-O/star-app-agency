# API Configuration
VITE_API_BASE_URL=https://startapp360.com/api/v1
VITE_AGENCY_API_URL=/api/agency
VITE_API_PROXY_URL=/api/proxy
VITE_USE_PROXY=false

# Agency companion server (local dev — proxy en vite.config.ts)
VITE_AGENCY_API_PORT=8001

# Django local (optional)
# VITE_DJANGO_API_URL=http://127.0.0.1:8000

# Login microservice
VITE_LOGIN_360_URL=https://login-360.vercel.app

# Authentication Storage Keys
VITE_JWT_STORAGE_KEY=auth_token
VITE_USERNAME_STORAGE_KEY=auth_username
VITE_PASSWORD_STORAGE_KEY=auth_password

# App Information
VITE_APP_NAME=Start App - Agency 360
VITE_APP_VERSION=1.0.0
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════════
# OAuth e integraciones → configurar en server/.env (no aquí)
# Copia server/.env.example → server/.env
#
# Para Google + Meta reales:
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI
#   META_APP_ID, META_APP_SECRET, META_REDIRECT_URI
#   ENABLED_INTEGRATIONS=google,meta,linkedin,x
#
# Modos:
#   demo   = sin keys OAuth → conexión simulada (google sin keys)
#   oauth  = con keys → autorización real
#   coming soon = linkedin/x sin keys → botón deshabilitado
# Contrato demo: /demo/contrato (independiente de integraciones)
# ═══════════════════════════════════════════════════════════════
