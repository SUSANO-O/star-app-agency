# ═══════════════════════════════════════════════════════════════
# SERVER — Agency API (puerto 8001)
# Copia a server/.env y rellena las claves que uses.
# Sin keys → modo demo (conexión simulada). Con keys → OAuth real.
# LinkedIn y X sin keys → "Coming soon" (no demo).
# ═══════════════════════════════════════════════════════════════

AGENCY_API_PORT=8001
FRONTEND_URL=http://localhost:5173

# Integraciones visibles en la UI: google, meta, linkedin, x
# google + meta con keys = OAuth real. Sin keys en google = demo.
# linkedin + x sin keys = próximamente (botón deshabilitado).
ENABLED_INTEGRATIONS=google,meta,linkedin,x

# ═══════════════════════════════════════════════════════════════
# Google Calendar — OAuth real (obligatorio para API real)
# Console: https://console.cloud.google.com
#   1. Activar "Google Calendar API"
#   2. OAuth consent → scope: .../auth/calendar.events
#   3. Credenciales OAuth Web → redirect URI abajo (debe coincidir exacto)
# ═══════════════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/agency/integrations/google/callback/
GOOGLE_CALENDAR_ID=primary

# ═══════════════════════════════════════════════════════════════
# Meta (Instagram + Facebook) — OAuth real
# Console: https://developers.facebook.com
#   1. Producto "Facebook Login"
#   2. Redirect URI válida: http://localhost:5173/integrations/callback
#   3. Permisos: pages_manage_posts, instagram_content_publish, pages_show_list
#   4. Requiere Facebook Page + Instagram Business vinculada
# ═══════════════════════════════════════════════════════════════
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:5173/integrations/callback
META_GRAPH_API_VERSION=21.0

# ═══════════════════════════════════════════════════════════════
# LinkedIn — próximamente hasta tener keys (luego OAuth real)
# Console: https://www.linkedin.com/developers
# Producto: "Share on LinkedIn" · scope: w_member_social
# ═══════════════════════════════════════════════════════════════
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5173/integrations/callback

# ═══════════════════════════════════════════════════════════════
# X (Twitter) — próximamente hasta tener keys
# Requiere plan de API de pago en developer.x.com
# ═══════════════════════════════════════════════════════════════
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:5173/integrations/callback

# ═══════════════════════════════════════════════════════════════
# Producción — actualizar redirect URIs a tu dominio real:
# FRONTEND_URL=https://tu-app.vercel.app
# GOOGLE_REDIRECT_URI=https://tu-api/api/v1/agency/integrations/google/callback/
# META_REDIRECT_URI=https://tu-app.vercel.app/integrations/callback
# LINKEDIN_REDIRECT_URI=https://tu-app.vercel.app/integrations/callback
# ═══════════════════════════════════════════════════════════════
